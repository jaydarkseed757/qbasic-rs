10 REM === THE ULTIMATE SELF-MODIFYING POKE MATRIX ===
20 CLS: DEFINT A-Z: RANDOMIZE TIMER: DEF SEG = 0: GOTO 100
30 A$ = LEFT$(Z$, 4): B$ = RIGHT$(Z$, 4): C$ = MID$(Z$, 3, 2): RETURN
40 PRINT "DECRYPTED OBJECTIVE: ";: FOR I = 1 TO LEN(K$): PRINT
CHR$(ASC(MID$(K$,I,1))-X);: NEXT I: PRINT: GOTO 210
50 X$ = "ERR": Y$ = "SYS": Z$ = X$ + "0" + Y$ + "1": GOSUB 30: RETURN
60 G$ = M$ + K$: K$ = RIGHT$(G$, LEN(G$) - 4): M$ = LEFT$(G$, 4): GOTO 170
70 RESTORE 350: FOR I = 1 TO 3: READ V: POKE 350 + (I * 2), V + X: NEXT I:
RETURN
