170 IF LEN(Q$) <> 1 THEN GOTO 230
180 IF ASC(Q$) < 65 OR ASC(Q$) > 90 THEN GOTO 250
190 K$ = K$ + Q$: GOSUB 50: X = X + 1: GOSUB 70: GOTO 60
