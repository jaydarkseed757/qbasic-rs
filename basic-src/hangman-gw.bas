10 CLS
20 RANDOMIZE TIMER
30 DIM W$(10)
40 W$(1)="COMPUTER"
50 W$(2)="KEYBOARD"
60 W$(3)="PROGRAM"
70 W$(4)="DATABASE"
80 W$(5)="NETWORK"
90 W$(6)="MONITOR"
100 W$(7)="PYTHON"
110 W$(8)="RUST"
120 W$(9)="GWBASIC"
130 W$(10)="PRINTER"
140 WD$=W$(INT(RND*10)+1)
150 GS$=""
160 WR=0
170 MX=6
180 CLS
190 PRINT "======================="
200 PRINT "        HANGMAN"
210 PRINT "======================="
220 PRINT
230 GOSUB 700
240 PRINT
250 PRINT "Word: ";
260 OK=1
270 FOR I=1 TO LEN(WD$)
280 L$=MID$(WD$,I,1)
290 IF INSTR(GS$,L$)>0 THEN PRINT L$;" "; ELSE PRINT "_ "; : OK=0
300 NEXT I
310 PRINT
320 PRINT
330 PRINT "Guessed: ";
340 FOR I=1 TO LEN(GS$)
350 PRINT MID$(GS$,I,1);" ";
360 NEXT I
370 PRINT
380 PRINT
390 PRINT "Wrong:";WR;"/";MX
400 PRINT
410 IF OK THEN PRINT "YOU WIN!" : GOTO 660
420 IF WR>=MX THEN PRINT "YOU LOSE! Word was: ";WD$ : GOTO 660
430 INPUT "Letter: ",G$
440 IF LEN(G$)=0 THEN GOTO 180
450 G$=UCASE$(LEFT$(G$,1))
460 IF G$<"A" OR G$>"Z" THEN PRINT "A-Z only!" : SLEEP 2 : GOTO 180
470 IF INSTR(GS$,G$)>0 THEN PRINT "Already guessed!" : SLEEP 2 : GOTO 180
480 GS$=GS$+G$
490 IF INSTR(WD$,G$)=0 THEN WR=WR+1
500 GOTO 180
660 PRINT
670 PRINT "Press ENTER to quit..."
680 LINE INPUT A$
690 END
700 REM ---- DRAW HANGMAN ----
710 PRINT " +----+"
720 PRINT " |"
730 IF WR>=1 THEN PRINT " |    O" ELSE PRINT " |"
740 IF WR=2 THEN PRINT " |    |" ELSE IF WR=3 THEN PRINT " |   /|" ELSE IF WR>=4 THEN PRINT " |   /|\" ELSE PRINT " |"
750 IF WR=5 THEN PRINT " |   /" ELSE IF WR>=6 THEN PRINT " |   / \" ELSE PRINT " |"
760 PRINT "_|_"
770 RETURN


