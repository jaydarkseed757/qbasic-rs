10 CLS
20 PRINT "GW-BASIC MEGA TEST"
30 PRINT STRING$(40, "=")

40 DIM N(10)
50 DIM NAME$(5)

60 DATA ALPHA,BETA,GAMMA,DELTA,OMEGA
70 FOR I=1 TO 5
80 READ NAME$(I)
90 NEXT I

100 FOR I=1 TO 10
110 N(I)=I*I
120 NEXT I

130 DEF FNSQ(X)=X*X
140 DEF FNDB(X)=X*2

150 RANDOMIZE TIMER

160 PRINT
170 PRINT "MAIN MENU"
180 PRINT "1 - ARRAY TEST"
190 PRINT "2 - RANDOM TEST"
200 PRINT "3 - STRING TEST"
210 PRINT "4 - GRAPHICS TEST"
220 PRINT "5 - ON GOTO TEST"
230 PRINT "6 - DATA TEST"
240 PRINT "7 - SUBROUTINE TEST"
250 PRINT "8 - COMPUTE TEST"
260 PRINT "9 - EXIT"

270 INPUT "CHOICE";C

280 ON C GOTO 1000,2000,3000,4000,5000,6000,7000,8000,9000

290 GOTO 160

1000 CLS
1010 PRINT "ARRAY TEST"
1020 FOR I=1 TO 10
1030 PRINT I;N(I)
1040 NEXT I
1050 GOSUB 9500
1060 GOTO 160

2000 CLS
2010 PRINT "RANDOM TEST"
2020 FOR I=1 TO 20
2030 PRINT INT(RND*100);
2040 NEXT I
2050 PRINT
2060 GOSUB 9500
2070 GOTO 160

3000 CLS
3010 PRINT "STRING TEST"
3020 A$="GWBASICTEST"
3030 PRINT A$
3040 PRINT LEFT$(A$,3)
3050 PRINT RIGHT$(A$,4)
3060 PRINT MID$(A$,4,5)
3070 GOSUB 9500
3080 GOTO 160

4000 CLS
4010 PRINT "GRAPHICS TEST"
4020 SCREEN 1
4030 FOR I=1 TO 100
4040 X1=INT(RND*320)
4050 Y1=INT(RND*200)
4060 X2=INT(RND*320)
4070 Y2=INT(RND*200)
4080 C=INT(RND*4)
4090 LINE (X1,Y1)-(X2,Y2),C
4100 NEXT I
4110 A$=INPUT$(1)
4120 SCREEN 0
4130 GOTO 160

5000 CLS
5010 PRINT "ON GOTO TEST"

5020 FOR I=1 TO 20
5030 X=INT(RND*4)+1
5040 ON X GOSUB 5100,5200,5300,5400
5050 NEXT I

5060 GOSUB 9500
5070 GOTO 160

5100 PRINT "SUB 1"
5110 RETURN

5200 PRINT "SUB 2"
5210 RETURN

5300 PRINT "SUB 3"
5310 RETURN

5400 PRINT "SUB 4"
5410 RETURN

6000 CLS
6010 PRINT "DATA TEST"

6020 RESTORE 60

6030 FOR I=1 TO 5
6040 READ A$
6050 PRINT A$
6060 NEXT I

6070 GOSUB 9500
6080 GOTO 160

7000 CLS
7010 PRINT "SUBROUTINE TEST"

7020 FOR I=1 TO 5
7030 GOSUB 7200
7040 NEXT I

7050 GOSUB 9500
7060 GOTO 160

7200 PRINT "CALL ";I
7210 RETURN

8000 CLS
8010 PRINT "COMPUTE TEST"

8020 FOR I=1 TO 10
8030 PRINT I;
8040 PRINT FNSQ(I);
8050 PRINT FNDB(I)
8060 NEXT I

8070 S=0

8080 I=1

8090 WHILE I<=100
8100 S=S+I
8110 I=I+1
8120 WEND

8130 PRINT
8140 PRINT "SUM=";S

8150 GOSUB 9500
8160 GOTO 160

9000 CLS
9010 PRINT "GOODBYE"
9020 END

9500 PRINT
9510 PRINT "PRESS ENTER"
9520 LINE INPUT A$
9530 RETURN


