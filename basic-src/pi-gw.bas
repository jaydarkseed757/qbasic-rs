10 REM PI CALCULATOR - MACHIN'S FORMULA
20 REM PI = 16*ARCTAN(1/5) - 4*ARCTAN(1/239)
30 REM N=15 TERMS IS ENOUGH FOR 10+ DECIMAL PLACES OF PRECISION
40 CLS
50 PRINT "PI CALCULATOR"
60 PRINT
70 N = 15
80 REM --- ARCTAN(1/5) VIA POWER SERIES ---
90 A# = 0#
100 X# = 1# / 5#
110 T# = X#
120 FOR I = 0 TO N - 1
130   A# = A# + T# / (2 * I + 1)
140   T# = -T# * X# * X#
150 NEXT I
160 REM --- ARCTAN(1/239) VIA POWER SERIES ---
170 B# = 0#
180 X# = 1# / 239#
190 T# = X#
200 FOR I = 0 TO N - 1
210   B# = B# + T# / (2 * I + 1)
220   T# = -T# * X# * X#
230 NEXT I
240 P# = 16# * A# - 4# * B#
250 PRINT "PI ="; P#
260 END
