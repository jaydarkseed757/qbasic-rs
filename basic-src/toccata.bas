REM QBC TITLE Bach - Toccata and Fugue in D minor (BWV 565)

' ============================================================
' Bach: Toccata and Fugue in D minor, BWV 565
' Monophonic QB PLAY transcription
' ============================================================

' == OPENING TOCCATA (Adagio) ==
' The famous solo announcement

PLAY "T60 O4 ML"

' First phrase: single A, ornament, descend to D
PLAY "A2"
PLAY "G#16 A8"
PLAY "A8 F8 E8 D#8 D2"

' Second phrase (repetition)
PLAY "P8"
PLAY "A2"
PLAY "G#16 A8"
PLAY "A8 F8 E8 D#8 C#8 D4"

' Ascending connecting figure
PLAY "E8 F8 G8 A8 O5 C8 O4 B8 A8 G8 F8 E8"

' Dramatic descending chromatic run to cadence
PLAY "O4 D8 C#8 D8 A8 F8 D8"
PLAY "O3 A16 F16 D8"

PLAY "P4"

' First D minor cadence figure (arpeggio up and down)
PLAY "O3 D16 F16 A16 O4 D8 O3 A16 F16 D16 C#16 D4"

' == TOCCATA PROPER ==
PLAY "T76 MN"

' Rising D minor arpeggio sweep
PLAY "O3 D16 F16 A16 O4 D16 F16 A16 D16 F16 A16 O5 D8"
PLAY "O4 A16 F16 D16 O3 A16 F16 D8"

' Bb major (the bVII) arpeggio
PLAY "O3 Bb16 D16 F16 O4 Bb16 D16 F16 Bb8"

' Resolving to A dominant
PLAY "O4 A16 E16 C#16 O3 A16 E16 C#16 A8"

' Return to D minor with running figure
PLAY "O3 D16 F16 A16 O4 D16 F16 A16 D8"
PLAY "O4 C#16 D16 E16 F16 E16 D8 C#16 D16"

' Pedal point on A with upper voices
PLAY "O4 A8 G8 A8 F8 E8 D8 C#4"

' == THE THREE FAMOUS CHORDS (arpeggiated) ==
PLAY "T60 ML"
PLAY "O3 D16 F16 A16 O4 D8 P8"
PLAY "O3 D16 F16 A16 O4 D8 P8"
PLAY "O3 D16 F16 A16 O4 D2"

' == FUGUE SUBJECT ==
' The famous four-voice fugue, presented as the solo subject
PLAY "T80 O3 MN"

' Subject entry 1 (bass)
PLAY "D4 D8 E8 F4 G4"
PLAY "A4 Bb4 A8 G8 F8 E8"
PLAY "F4 G4 A4 D2"

' Subject entry 2 (tenor, one octave up)
PLAY "O4"
PLAY "D4 D8 E8 F4 G4"
PLAY "A4 Bb4 A8 G8 F8 E8"
PLAY "F4 G4 A4 D2"

' Episode — flowing eighth note passage
PLAY "T84 O3 ML"
PLAY "F8 G8 A8 Bb8 A8 G8 F8 E8"
PLAY "D8 E8 F8 G8 F8 E8 D8 C#8"
PLAY "D4 A4 F4 D4"

' Subject entry 3 (soprano, two octaves up from bass)
PLAY "T80 O4 MN"
PLAY "D4 D8 E8 F4 G4"
PLAY "A4 Bb4 A8 G8 F8 E8"
PLAY "F4 G4 A4 D2"

' == RETURN TO TOCCATA STYLE ==
PLAY "T72 O4 ML"
PLAY "A8 G8 F8 E8 D8 C#8 D4"

' Final ascending sweep
PLAY "O3 D16 F16 A16 O4 D16 F16 A16 D16"

' == CLOSING PEDAL POINT (Adagio) ==
PLAY "T50 O3"
PLAY "ML D8 F8 A8 O4 D8 F8 A8 O5 D4"
PLAY "O4 A8 F8 D8 O3 A8 F8 D8"

' The final held D minor chord (arpeggiated slowly)
PLAY "O2 D16 O3 D16 F16 A16 O4 D4"
PLAY "O2 D2"
